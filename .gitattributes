# Normaliza los finales de línea a LF: el repo se construye en Linux (Docker / HF).
* text=auto eol=lf

# Binarios: que Git no toque sus finales de línea.
*.jpg binary
*.ico binary
*.whl binary

# Imágenes de capturas: almacenadas en Git LFS (GitHub y HF las aceptan así).
*.png filter=lfs diff=lfs merge=lfs -text
